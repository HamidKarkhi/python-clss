   ],
   "source": [
    "num = int(input(\"Enter the number\"))\n",
    "org = num\n",
    "rev = 0\n",
    "while num>0:\n",
    "    dig =num%10\n",
    "    rev = rev*10+dig\n",
    "    num = num//10\n",
    "if org == rev:\n",
    "    print(\"The number is palindrome\")\n",
    "else:\n",
    "    print(\"The Number is not palindrome\")\n",
    "    "
   ]
  }
